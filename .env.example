APP_NAME=Golite
APP_ENV=local
APP_PORT=:8080
# APP_DEBUG defaults to true unless APP_ENV=production; set explicitly to override.
# APP_DEBUG=true
# APP_KEY is a base64-encoded 32-byte (AES-256) key used by the encryption
# package (Crypt-equivalent). Leave unset in development — Golite generates
# an ephemeral one and logs a warning; set this in production so encrypted
# values survive a restart. Generate one with: openssl rand -base64 32
# APP_KEY=base64:...
# Database (see docs/database.md): MySQL via GORM. DB_DATABASE/DB_USERNAME
# must exist already — Golite creates tables via migrations
# (`go run artisan.go migrate`), never the database itself.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=golite
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME_MINUTES=60

# Logging (see docs/logging.md): LOG_CHANNEL selects "single", "daily", or "stack".
LOG_CHANNEL=single
LOG_PATH=storage/logs/golite.log
LOG_DAILY_DAYS=14

# Hashing (see docs/hashing.md)
HASH_DRIVER=bcrypt
HASH_BCRYPT_COST=10
